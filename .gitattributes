# Force LF for source files — tests read them and expect LF newlines.
*.rs    text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.ts    text eol=lf
*.html  text eol=lf
*.css   text eol=lf

# Binary — leave alone.
*.png   binary
*.jpg   binary
*.ico   binary
*.gpk   binary
*.dat   binary
*.exe   binary
*.dll   binary
