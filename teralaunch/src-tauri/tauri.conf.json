{
    "build": {
        "devPath": "../src",
        "distDir": "../src",
        "withGlobalTauri": true
    },
    "package": {
        "productName": "TERA-Europe-Launcher",
        "version": "1.1.6"
    },
    "tauri": {
        "allowlist": {
            "all": true,
            "shell": {
                "all": true,
                "open": true
            }
        },
        "windows": [
            {
                "title": "TERA-Europe-Launcher",
                "width": 1282,
                "height": 759,
                "resizable": false,
                "decorations": false,
                "transparent": true,
                "center": true,
                "contentProtected": false,
                "url": "index.html"
            }
        ],
        "security": {
            "csp": null
        },
        "bundle": {
            "active": true,
            "targets": "all",
            "identifier": "crazy-esports",
            "publisher": "Crazy-eSports",
            "icon": [
                "icons/tera_server.png",
                "icons/tera_server.ico"
            ],
            "copyright": "Crazy-eSports",
            "shortDescription": "TERA-Europe-Launcher",
            "resources": [
                "./src/TERA/readme.txt"
            ],
            "windows": {
                "nsis": {
                    "license": "../license.txt",
                    "installMode": "perMachine"
                }
            }
        }
    }
}
